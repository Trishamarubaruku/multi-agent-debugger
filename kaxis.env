// ===============================
// GITHUB PR CREATION (DebugHive)
// ===============================

const GITHUB_TOKEN = process.env.GITHUB_TOKEN; // stored in .env
const OWNER = "your-username"; // repo owner
const REPO = "your-repo"; // repo name

// Function to create a Pull Request
async function createPullRequest() {
  const url = `https://api.github.com/repos/${OWNER}/${REPO}/pulls`;

  const prData = {
    title: "Fix: Variable declaration issue",
    body: `
### 🐞 Bug Fix by DebugHive

**Issue:**
Used 'var' instead of 'const'

**Fix:**
Replaced with 'const' to avoid scope issues

**AI Agents Used:**
- Bug Finder
- Fixer
- Reviewer
    `,
    head: "feature/debughive-fix", // your branch
    base: "main" // target branch
  };

  try {
    const response = await fetch(url, {
      method: "POST",
      headers: {
        "Authorization": `Bearer ${GITHUB_TOKEN}`,
        "Accept": "application/vnd.github+json",
        "Content-Type": "application/json"
      },
      body: JSON.stringify(prData)
    });

    const data = await response.json();

    if (response.ok) {
      console.log("✅ PR Created Successfully!");
      console.log("🔗 PR URL:", data.html_url);
    } else {
      console.error("❌ Error creating PR:", data);
    }

  } catch (error) {
    console.error("⚠️ Network Error:", error);
  }
}

// Run function
createPullRequest();
